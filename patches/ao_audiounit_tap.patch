 #import <AudioToolbox/AudioToolbox.h>
 #import <AVFoundation/AVFoundation.h>
 #import <mach/mach_time.h>
+
+// ==== 音频 TAP 回调 (自定义修改) ====
+// 外部可以通过此函数设置回调，获取送往喇叭的音频数据。
+// 回调运行在 CoreAudio 渲染线程，必须无阻塞、无锁，不能分配内存。
+static void (*audio_tap_cb)(void *data, size_t size, void *ctx) = NULL;
+static void *audio_tap_ctx = NULL;
+
+__attribute__((visibility("default")))
+void mpv_ao_coreaudio_set_tap_callback(
+    void (*callback)(void *data, size_t size, void *ctx),
+    void *ctx)
+{
+    audio_tap_cb = callback;
+    audio_tap_ctx = ctx;
+}
+// ==== 音频 TAP 回调结束 ====
 
 struct priv {
     AudioUnit audio_unit;
@@ -98,6 +114,18 @@
     end += p->device_latency * 1e6;
     end += ca_get_latency(ts) + ca_frames_to_us(ao, frames);
     ao_read_data(ao, planes, frames, end);
+    
+      // ==== 音频 TAP: 将已填充的 PCM 数据拷贝给外部回调 ====
+    if (audio_tap_cb) {
+        for (UInt32 i = 0; i < buffer_list->mNumberBuffers; i++) {
+            AudioBuffer buf = buffer_list->mBuffers[i];
+            if (buf.mDataByteSize > 0) {
+                audio_tap_cb(buf.mData, buf.mDataByteSize, audio_tap_ctx);
+            }
+        }
+    }
+    // ==== TAP 结束 ====
+
     return noErr;
 }
 
