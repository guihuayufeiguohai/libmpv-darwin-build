+static void bluray_stream_close(stream_t *s) {
+    struct bluray_priv_s *priv = s->priv;
+    if (!priv) return;
+
+#if HAVE_LIBCURL
+    if (priv->remote_fs_ctx) {
+        http_udf_fs_destroy(priv->remote_fs_ctx);
+        priv->remote_fs_ctx = NULL;
+    }
+    talloc_free(priv->remote_device);
+#endif
+
+    if (priv->title_info)
+        bd_free_title_info(priv->title_info);
+    if (priv->bd)
+        bd_close(priv->bd);
 }
 
