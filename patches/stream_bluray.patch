+/* ---------- HTTP Blu-ray stream callback & opener ---------- */
+static int http_read_cb(void *handle, void *buf, int lba, int num_blocks)
+{
+    struct stream *s = handle;
+    int64_t pos = (int64_t)lba * 2048;
+    if (stream_seek(s, pos) < 0)
+        return -1;
+
+    int size = num_blocks * 2048;
+    int read_bytes = stream_read(s, buf, size);
+    return (read_bytes == size) ? num_blocks : -1;
+}
+
+static int open_bd_http(stream_t *stream, const char *url)
+{
+    struct bluray_priv_s *b = stream->priv;
+    struct mpv_global *global = stream->global;
+
+    struct stream *http_stream = stream_create(url, STREAM_READ, NULL, global);
+    if (!http_stream)
+        return STREAM_UNSUPPORTED;
+
+    // 用 bd_init() 创建未打开的 BLURAY 句柄
+    BLURAY *bd = bd_init();
+    if (!bd) {
+        free_stream(http_stream);
+        return STREAM_UNSUPPORTED;
+    }
+
+    // 绑定自定义读取回调，成功后 bd 即可正常使用
+    if (bd_open_stream(bd, http_stream, http_read_cb) <= 0) {
+        bd_close(bd);
+        free_stream(http_stream);
+        return STREAM_UNSUPPORTED;
+    }
+
+    b->bd = bd;
+    b->http_stream = http_stream;   // 保存以便后续释放
 
+    MP_VERBOSE(stream, "Opened Blu-ray over HTTP: %s\n", url);
+    return STREAM_OK;
+}
+/* ---------- end of HTTP additions ---------- */
