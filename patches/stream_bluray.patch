+/* ---------- HTTP Blu-ray stream callbacks ---------- */
+static int http_read_cb(void *stream_ptr, uint8_t *buf, int lba, int num_blocks)
+{
+    struct stream *s = stream_ptr;
+    int64_t pos = (int64_t)lba * 2048;
+    if (stream_seek(s, pos) < 0)
+        return -1;
+
+    int size = num_blocks * 2048;
+    int read_bytes = stream_read(s, buf, size);
+    return (read_bytes == size) ? num_blocks : -1;
+}
+
+static int64_t http_seek_cb(void *stream_ptr, int64_t offset, int whence)
+{
+    struct stream *s = stream_ptr;
+    int64_t base;
+    switch (whence) {
+    case SEEK_SET: base = 0; break;
+    case SEEK_CUR: base = stream_tell(s); break;
+    case SEEK_END: base = stream_get_size(s); break;
+    default: return -1;
+    }
+    int64_t new_pos = base + offset;
+    if (new_pos < 0) return -1;
+    if (stream_seek(s, new_pos) < 0) return -1;
+    return new_pos;
+}
+
+static void http_close_cb(void *stream_ptr)
+{
+    struct stream *s = stream_ptr;
+    free_stream(s);
+}
+
+static int open_bd_http(stream_t *stream, const char *url)
+{
+    struct bluray_priv_s *b = stream->priv;
+    struct mpv_global *global = stream->global;
+
+    /* 使用 STREAM_READ 即可，mpv 会根据 URL 自动启用网络能力 */
+    struct stream *http_stream = stream_create(url,
+                                STREAM_READ,
+                                NULL, global);
+    if (!http_stream)
+        return STREAM_UNSUPPORTED;
 
+    BD_STREAM_INFO info = {
+        .stream = http_stream,
+        .read   = http_read_cb,
+        .seek   = http_seek_cb,
+        .close  = http_close_cb,
+    };
+
+    BLURAY *bd = bd_open_stream(&info);
+    if (!bd) {
+        free_stream(http_stream);
+        return STREAM_UNSUPPORTED;
+    }
+
+    /* 缓存功能不可用，移除了 bd_set_cache_size 调用 */
+    b->bd = bd;
+
+    MP_VERBOSE(stream, "Opened Blu-ray over HTTP: %s\n", url);
+    return STREAM_OK;
+}
+/* ---------- end of HTTP additions ---------- */
