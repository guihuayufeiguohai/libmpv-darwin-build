+#include "http_udf_fs.h"
+#include <stdlib.h>
+#include <string.h>
+#include <curl/curl.h>
+
+// ------------------- 内部数据结构 -------------------
+typedef struct fs_node {
+    char *name;               // 文件名或目录名
+    int   is_dir;             // 1 = 目录，0 = 文件
+    uint64_t start_sector;    // 文件起始扇区（绝对扇区号）
+    uint64_t size;            // 文件大小（字节）
+    struct fs_node *children; // 目录的子节点数组
+    int   child_count;
+} fs_node;
+
+typedef struct {
+    char    *iso_url;         // 远程 ISO URL
+    fs_node *root;            // 根目录节点（/）
+    // 可添加缓存等
+} remote_fs_ctx;
+
+static remote_fs_ctx *g_ctx = NULL;   // 全局实例（简化，实际应放在回调参数中）
+
+// ------------------- 工具函数 -------------------
+// 在节点树中根据路径查找节点（需要实现）
+static fs_node *find_node(fs_node *root, const char *path) {
+    // 实现路径解析，找到对应节点，返回 NULL 表示未找到
+    return NULL;
+}
+
+// 发送 HTTP Range 请求读取数据
+static int http_read(const char *url, uint64_t offset, size_t size, uint8_t *buf) {
+    CURL *curl = curl_easy_init();
+    if (!curl) return -1;
+    char range[128];
+    snprintf(range, sizeof(range), "%llu-%llu", 
+             (unsigned long long)offset, (unsigned long long)(offset + size - 1));
+    curl_easy_setopt(curl, CURLOPT_URL, url);
+    curl_easy_setopt(curl, CURLOPT_RANGE, range);
+    // 设置写入回调（需自己实现一个简单的写入函数）
+    // CURLOPT_WRITEFUNCTION, CURLOPT_WRITEDATA ...
+    CURLcode res = curl_easy_perform(curl);
+    curl_easy_cleanup(curl);
+    return (res == CURLE_OK) ? (int)size : -1;
+}
+
+// UDF 解析核心（仅示意，需完整实现）
+static int parse_udf_from_url(const char *url, fs_node **root) {
+    // 1. 读取 Anchor Volume Descriptor (sector 256)
+    uint8_t sector[2048];
+    if (http_read(url, 256 * 2048, 2048, sector) != 2048) return -1;
+    // 2. 找到 Main Volume Descriptor Sequence 起始扇区
+    // 3. 读取 Logical Volume Descriptor，找到 File Set Descriptor
+    // 4. 从 File Set Descriptor 读取根目录的 FID（File Identifier Descriptor）
+    // 5. 遍历目录树，记录所有 BDMV 目录下的文件和子目录
+    // 6. 构建 fs_node 树
+    // ...
+    *root = calloc(1, sizeof(fs_node));
+    (*root)->name = strdup("/");
+    (*root)->is_dir = 1;
+    return 0;
+}
+
+// ------------------- 文件操作回调实现 -------------------
+typedef struct {
+    BD_FILE_H  base;
+    fs_node   *node;
+    int64_t    position;      // 当前文件内偏移
+} http_udf_file;
+
+static void file_close(BD_FILE_H *file) {
+    http_udf_file *f = (http_udf_file *)file;
+    free(f);
+}
+
+static int64_t file_seek(BD_FILE_H *file, int64_t offset, int32_t origin) {
+    http_udf_file *f = (http_udf_file *)file;
+    if (origin == SEEK_SET) f->position = offset;
+    else if (origin == SEEK_CUR) f->position += offset;
+    else if (origin == SEEK_END) f->position = f->node->size + offset;
+    return f->position;
+}
+
+static int64_t file_tell(BD_FILE_H *file) {
+    return ((http_udf_file *)file)->position;
+}
+
+static int file_eof(BD_FILE_H *file) {
+    http_udf_file *f = (http_udf_file *)file;
+    return f->position >= f->node->size;
+}
+
+static int64_t file_read(BD_FILE_H *file, uint8_t *buf, int64_t size) {
+    http_udf_file *f = (http_udf_file *)file;
+    if (size <= 0) return 0;
+    if (f->position + size > f->node->size)
+        size = f->node->size - f->position;
+    if (size == 0) return 0;
+
+    uint64_t start_byte = f->node->start_sector * 2048ULL + f->position;
+    int ret = http_read(g_ctx->iso_url, start_byte, (size_t)size, buf);
+    if (ret > 0) f->position += ret;
+    return ret;
+}
+
+static int64_t file_write(BD_FILE_H *file, const uint8_t *buf, int64_t size) {
+    (void)file; (void)buf; (void)size;
+    return -1; // 不支持写入
+}
+
+BD_FILE_H *http_udf_file_open(const char *filename, const char *mode) {
+    if (!g_ctx || !g_ctx->root) return NULL;
+    if (mode[0] != 'r') return NULL;   // 只读
+
+    fs_node *node = find_node(g_ctx->root, filename);
+    if (!node || node->is_dir) return NULL;
+
+    http_udf_file *f = calloc(1, sizeof(http_udf_file));
+    f->base.close = file_close;
+    f->base.seek  = file_seek;
+    f->base.tell  = file_tell;
+    f->base.eof   = file_eof;
+    f->base.read  = file_read;
+    f->base.write = file_write;
+    f->node = node;
+    f->position = 0;
+    return (BD_FILE_H *)f;
+}
+
+// ------------------- 目录操作回调实现 -------------------
+typedef struct {
+    BD_DIR_H base;
+    fs_node  *dir_node;
+    int       index;
+} http_udf_dir;
+
+static void dir_close(BD_DIR_H *dir) {
+    http_udf_dir *d = (http_udf_dir *)dir;
+    free(d);
+}
+
+static int dir_read(BD_DIR_H *dir, BD_DIRENT *entry) {
+    http_udf_dir *d = (http_udf_dir *)dir;
+    if (!d->dir_node || d->index >= d->dir_node->child_count) return 1; // EOF
+    fs_node *child = &d->dir_node->children[d->index++];
+    strncpy(entry->d_name, child->name, sizeof(entry->d_name) - 1);
+    entry->d_name[sizeof(entry->d_name) - 1] = '\0';
+    return 0;
+}
+
+BD_DIR_H *http_udf_dir_open(const char *dirname) {
+    if (!g_ctx || !g_ctx->root) return NULL;
+    fs_node *node = find_node(g_ctx->root, dirname);
+    if (!node || !node->is_dir) return NULL;
+
+    http_udf_dir *d = calloc(1, sizeof(http_udf_dir));
+    d->base.close = dir_close;
+    d->base.read  = dir_read;
+    d->dir_node = node;
+    d->index = 0;
+    return (BD_DIR_H *)d;
+}
+
+// ------------------- 初始化与销毁 -------------------
+void *http_udf_fs_init(const char *iso_url) {
+    if (g_ctx) http_udf_fs_destroy(g_ctx);  // 防止重复初始化
+
+    remote_fs_ctx *ctx = calloc(1, sizeof(remote_fs_ctx));
+    ctx->iso_url = strdup(iso_url);
+    if (parse_udf_from_url(iso_url, &ctx->root) != 0) {
+        free(ctx->iso_url);
+        free(ctx);
+        return NULL;
+    }
+    g_ctx = ctx;
+    return ctx;
+}
+
+void http_udf_fs_destroy(void *ctx) {
+    if (!ctx) return;
+    remote_fs_ctx *c = (remote_fs_ctx *)ctx;
+    free(c->iso_url);
+    // 递归释放文件树（需自行实现）
+    free(c);
+    if (g_ctx == c) g_ctx = NULL;
+}
