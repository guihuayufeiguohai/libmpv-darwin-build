+// ==== 音频 TAP 回调 (自定义修改) ====
+// 外部可以通过此函数设置回调，获取送往喇叭的音频数据。
+// 回调运行在 CoreAudio 渲染线程，必须无阻塞、无锁，不能分配内存。
+static void (*audio_tap_cb)(void *data, size_t size, void *ctx) = NULL;
+static void *audio_tap_ctx = NULL;
+
+__attribute__((visibility("default")))
+void mpv_ao_coreaudio_set_tap_callback(
+    void (*callback)(void *data, size_t size, void *ctx),
+    void *ctx)
+{
+    audio_tap_cb = callback;
+    audio_tap_ctx = ctx;
+}
+// ==== 音频 TAP 回调结束 ====
 
